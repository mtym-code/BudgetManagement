<Page x:Class="BudgetManagement.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">

    <Page.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="#F9FAFB" CornerRadius="3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Color="#22000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="bd" Background="#F9FAFB" CornerRadius="3" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="28,28,28,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="メインメニュー" FontSize="28" FontWeight="SemiBold" Foreground="#6366F1"/>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock Text="ユーザー：109999 五反田 一郎" FontSize="12" Foreground="#9CA3AF"/>
                <TextBlock Text="端末：26B-0001" FontSize="12" Foreground="#9CA3AF"/>
                <TextBlock Text="Ver：1.01" FontSize="12" Foreground="#9CA3AF"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="28,0,0,0">
            <Border x:Name="TabBudget" MouseLeftButtonDown="TabBudget_Click" Background="White" CornerRadius="8,8,0,0" BorderBrush="#6366F1" BorderThickness="1,1,1,0" Padding="48,10" Cursor="Hand">
                <TextBlock Text="予算入力" FontSize="14" FontWeight="SemiBold" Foreground="#6366F1"/>
            </Border>
            <Border x:Name="TabMaintenance" MouseLeftButtonDown="TabMaintenance_Click" Background="#E5E7EB" CornerRadius="8,8,0,0" BorderBrush="#E5E7EB" BorderThickness="1" Padding="48,10" Cursor="Hand">
                <TextBlock Text="メンテナンス" FontSize="14" FontWeight="SemiBold" Foreground="#6366F1"/>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Margin="28,-2,28,28" CornerRadius="8" Background="#EDF3FF" BorderBrush="#E5E7EB" BorderThickness="1,0,1,1" Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <StackPanel x:Name="BudgetPanel">
                        <TextBlock Text="長期予算" FontSize="20" FontWeight="Bold" Foreground="#4B5563" Margin="0,0,0,14"/>
                        <WrapPanel>
                            <Button Style="{StaticResource MenuButton}" Content="部門経費予算" Click="DepartmentBudget_Click"/>
                            <Button Style="{StaticResource MenuButton}" Content="ユーザーCSVインポート" Click="UserCsvImport_Click"/>
                            <Button Style="{StaticResource MenuButton}" Content="社内売上仕入"/>
                            <Button Style="{StaticResource MenuButton}" Content="課別営業予算"/>
                            <Button Style="{StaticResource MenuButton}" Content="人件費取り込み"/>
                            <Button Style="{StaticResource MenuButton}" Content="得意先別営業予算"/>
                            <Button Style="{StaticResource MenuButton}" Content="ショップ別経費"/>
                            <Button Style="{StaticResource MenuButton}" Content="配賦関連入力"/>
                        </WrapPanel>

                        <TextBlock Text="見通し予算" FontSize="20" FontWeight="Bold" Foreground="#4B5563" Margin="0,24,0,14"/>
                        <WrapPanel>
                            <Button Style="{StaticResource MenuButton}" Content="社内売上仕入"/>
                            <Button Style="{StaticResource MenuButton}" Content="課別営業予算"/>
                            <Button Style="{StaticResource MenuButton}" Content="経費・営業外" Click="ExpenseNonOperatingForecast_Click"/>
                        </WrapPanel>
                        <TextBlock Text="照会・その他" FontSize="20" FontWeight="Bold" Foreground="#4B5563" Margin="0,24,0,14"/>
                        <WrapPanel>
                            <Button Style="{StaticResource MenuButton}" Content="照会"/>
                            <Button Style="{StaticResource MenuButton}" Content="課別見通し連携起動"/>
                            <Button Style="{StaticResource MenuButton}" Content="社内売上作成（長期）起動"/>
                            <Button Style="{StaticResource MenuButton}" Content="社内売上作成（見通し）起動"/>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel x:Name="MaintenancePanel" Visibility="Collapsed">
                        <TextBlock Text="メンテナンス" FontSize="20" FontWeight="Bold" Margin="0,0,0,14"/>
                        <WrapPanel>
                            <Button Style="{StaticResource MenuButton}" Content="予算運用マスタ"/>
                            <Button Style="{StaticResource MenuButton}" Content="予算係数マスタ"/>
                            <Button Style="{StaticResource MenuButton}" Content="担当者マスタ"/>
                            <Button Style="{StaticResource MenuButton}" Content="科目マスタ"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>