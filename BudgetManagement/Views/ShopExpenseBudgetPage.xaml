<Page x:Class="BudgetManagement.Views.ShopExpenseBudgetPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Background="White"
      Title="ショップ経費予算表">

    <Grid x:Name="MainRoot" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="ショップ経費予算表" FontSize="24" FontWeight="Bold" Foreground="#111827"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="更新" Width="100" Height="36" Cursor="Hand" Background="#10B981" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="15" Margin="0,0,8,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Padding="24" Margin="0,0,0,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="年度" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="15" Foreground="#4B5563"/>
                        <TextBlock Text="*" Foreground="Red" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="15"/>
                        <TextBox Width="80" Height="32" FontSize="15" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" MaxLength="4" 
                                 Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                        <TextBlock Text="得意先" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="15" Foreground="#4B5563"/>
                        <TextBlock Text="*" Foreground="Red" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="15"/>

                        <ComboBox Width="240" Height="32" FontSize="15" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"
                          ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}"
                          VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding NameCode}" />
                                        <TextBlock Text="：" />
                                        <TextBlock Text="{Binding AbbreviationName}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </WrapPanel>

                <Border Grid.Column="2" Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="6" Padding="12,8" Width="280">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="14" FontWeight="Bold" Foreground="#475569" TextAlignment="Center">
                            <Run Text="経"/><LineBreak/>
                            <Run Text="費"/><LineBreak/>
                            <Run Text="率"/>
                        </TextBlock>

                        <DataGrid Grid.Column="1" ItemsSource="{Binding ExpenseRates}" AutoGenerateColumns="False" 
                                  HeadersVisibility="Column" CanUserAddRows="False" IsReadOnly="True"
                                  Background="White" BorderBrush="#D1D5DB" RowHeight="24" ColumnHeaderHeight="24"
                                  Height="76" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="事業部名" Binding="{Binding DivisionName}" Width="*"/>
                                <DataGridTextColumn Header="割合" Binding="{Binding Rate, StringFormat={}{0:F1}%}" Width="70">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Right"/>
                                            <Setter Property="Padding" Value="0,0,8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" BorderBrush="#D1D5DB" BorderThickness="1">
            <Wpf:WebView2 x:Name="PreviewWebView" />
        </Border>
        <Popup IsOpen="{Binding IsLoading}" PlacementTarget="{Binding ElementName=MainRoot}" Placement="Center" AllowsTransparency="True">
            <Border Background="White" CornerRadius="8" Padding="32,24" BorderBrush="#D1D5DB" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="16" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="240" Height="6" Foreground="#2563EB" BorderThickness="0" Margin="0,0,0,16"/>
                    <TextBlock Text="データを読み込んでいます..." Foreground="#111827" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Page>