<Page x:Class="BudgetManagement.Views.ExpenseNonOperatingForecastPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      xmlns:constants="clr-namespace:BudgetManagement.Common.Constants"
      Background="White"
      Title="経費営業外見通し">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="TabRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="32,12"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1,1,1,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#2563EB"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                                <Setter Property="BorderThickness" Value="1,3,1,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid x:Name="MainRoot">
        <Grid Margin="24" IsEnabled="{Binding IsNotLoading}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="経費営業外見通し" FontSize="24" FontWeight="Bold" Foreground="#111827"/>

                <Button Grid.Column="1" Content="入力完了" Width="120" Height="40" Cursor="Hand"
                        Background="#10B981" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="15"
                        Command="{Binding CompleteInputCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="IsEnabled" Value="{Binding IsCompleteButtonEnabled}"/>
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=TabImport}" Value="True">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,-1" Panel.ZIndex="1">
                <RadioButton x:Name="TabPreview" Content="現在の予算 (データベース)" GroupName="MainTabs" IsChecked="True" Style="{StaticResource TabRadioButtonStyle}" />
                <RadioButton x:Name="TabImport" Content="Excel 取り込みプレビュー" GroupName="MainTabs" Style="{StaticResource TabRadioButtonStyle}" />
            </StackPanel>

            <Grid Grid.Row="2">
                <Border BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Padding="24">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=TabPreview}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                                <TextBlock Text="年度" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15" Foreground="#4B5563"/>
                                <TextBox Width="80" Height="32" FontSize="15" VerticalContentAlignment="Center" BorderBrush="#D1D5DB" MaxLength="4" 
                                         Text="{Binding Year, UpdateSourceTrigger=PropertyChanged}">
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="LostFocus">
                                            <i:InvokeCommandAction Command="{Binding HandleYearLostFocusCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                                <TextBlock Text="会社" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15" Foreground="#4B5563"/>
                                <ComboBox Width="200" Height="32" FontSize="15" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"
                                          ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding CompanyCode}" />
                                                <TextBlock Text="：" />
                                                <TextBlock Text="{Binding CompanyName}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="SelectionChanged">
                                            <i:InvokeCommandAction Command="{Binding HandleSelectionChangedCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,32,0">
                                <TextBlock Text="月" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="15" Foreground="#4B5563"/>
                                <ComboBox Width="100" Height="32" FontSize="15" VerticalContentAlignment="Center" BorderBrush="#D1D5DB"
                                          ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedMonth}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Month, StringFormat='{}{0}月'}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <i:Interaction.Triggers>
                                        <i:EventTrigger EventName="SelectionChanged">
                                            <i:InvokeCommandAction Command="{Binding HandleSelectionChangedCommand}" />
                                        </i:EventTrigger>
                                    </i:Interaction.Triggers>
                                </ComboBox>
                            </StackPanel>

                            <TextBlock Text="{Binding StatusText, StringFormat='状態：{0}'}" VerticalAlignment="Center" FontSize="15" Margin="0,0,32,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StatusText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="{x:Static constants:StatusConstants.Completed}">
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StatusText}" Value="{x:Static constants:StatusConstants.Uncompleted}">
                                                <Setter Property="Foreground" Value="#2563EB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button Content="Excel出力" Width="100" Height="32" Background="White" BorderBrush="#9CA3AF" BorderThickness="1" Cursor="Hand"
                                    Command="{Binding ExportExcelCommand}"/>
                        </WrapPanel>

                        <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding DbPreviewPlaceholderVisibility}">
                                    <ProgressBar IsIndeterminate="True" Width="160" Height="4" Margin="0,0,0,16" Foreground="#2563EB" BorderThickness="0"
                                                 Visibility="{Binding IsPreviewLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <TextBlock Text="上部の「年度」「会社」「月」を選択すると、現在登録されている予算データが表示されます。" 
                                               Foreground="#9CA3AF" FontSize="15" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <Wpf:WebView2 x:Name="SearchPreviewWebView" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border BorderBrush="#D1D5DB" BorderThickness="1" Background="White" Padding="24">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChecked, ElementName=TabImport}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16" VerticalAlignment="Center">
                            <Button Content="ファイル選択" Width="120" Height="36" Cursor="Hand"
                                    Background="White" BorderBrush="#9CA3AF" BorderThickness="1" FontWeight="Bold"
                                    Command="{Binding SelectAndImportFileCommand}" Margin="0,0,32,8" />

                            <StackPanel Orientation="Horizontal" Margin="0,0,32,8">
                                <TextBlock Text="年度" VerticalAlignment="Center" Foreground="#4B5563"/>
                                <Border Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="16,6" Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="80">
                                    <TextBlock Text="{Binding ImportYearInfo}" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,32,8">
                                <TextBlock Text="会社" VerticalAlignment="Center" Foreground="#4B5563"/>
                                <Border Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="16,6" Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="200">
                                    <TextBlock Text="{Binding ImportCompanyInfo}" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Left"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,32,8">
                                <TextBlock Text="月" VerticalAlignment="Center" Foreground="#4B5563"/>
                                <Border Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="16,6" Margin="12,0,0,0" VerticalAlignment="Center" MinWidth="80">
                                    <TextBlock Text="{Binding ImportMonthInfo}" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <TextBlock Text="{Binding ImportStatusText, StringFormat='状態：{0}'}" VerticalAlignment="Center" FontSize="15" Margin="0,0,0,8">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ImportStatusText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ImportStatusText}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ImportStatusText}" Value="{x:Static constants:StatusConstants.Completed}">
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ImportStatusText}" Value="{x:Static constants:StatusConstants.Uncompleted}">
                                                <Setter Property="Foreground" Value="#2563EB"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </WrapPanel>

                        <Border Grid.Row="1" BorderBrush="#D1D5DB" BorderThickness="1">
                            <Grid>
                                <TextBlock Text="※ファイルを選択するとプレビューが表示されます。" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" 
                                           Foreground="#9CA3AF" FontSize="15">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ImportYearInfo}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding ImportYearInfo}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Wpf:WebView2 x:Name="PreviewWebView" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Content="クリア" Width="100" Height="40" Margin="0,0,16,0" Cursor="Hand"
                                    Background="White" BorderBrush="#9CA3AF" BorderThickness="1"
                                    Command="{Binding ClearImportFieldsCommand}"/>

                            <Button Content="DBへ保存" Width="120" Height="40" Cursor="Hand"
                                    Background="#2563EB" Foreground="White" BorderThickness="0" FontWeight="Bold" FontSize="15"
                                    Command="{Binding CommitImportCommand}"
                                    IsEnabled="{Binding IsCommitButtonEnabled}">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Popup IsOpen="{Binding IsLoading}" PlacementTarget="{Binding ElementName=MainRoot}" Placement="Center" AllowsTransparency="True">
            <Border Background="White" CornerRadius="8" Padding="32,24" BorderBrush="#D1D5DB" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="16" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel>
                    <ProgressBar IsIndeterminate="True" Width="240" Height="6" Foreground="#2563EB" BorderThickness="0" Margin="0,0,0,16"/>
                    <TextBlock Text="処理中です..." Foreground="#111827" FontSize="15" FontWeight="Bold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Page>