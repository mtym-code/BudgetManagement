<Page x:Class="BudgetManagement.Views.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#EEF2FF">

    <Page.Resources>

        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="#F9FAFB" CornerRadius="3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Color="#22000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="bd" Background="#F9FAFB" CornerRadius="3" BorderBrush="#E5E7EB" BorderThickness="1" Padding="12">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="0,0,4,0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="#F9FAFB" CornerRadius="3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="4" ShadowDepth="1" Color="#22000000"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="3" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                <Setter Property="Foreground" Value="#6366F1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuTextLink" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#6366F1"/>
                    <Setter Property="Background" Value="#F3F4F6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Grid.Row="0">
            <StackPanel>

                <Grid Margin="16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="NavBudget" Text="予算入力" FontWeight="SemiBold" FontSize="14" Cursor="Hand" Margin="0,0,24,0" MouseLeftButtonUp="NavBudget_Click" Background="Transparent"/>
                        <TextBlock x:Name="NavMaintenance" Text="メンテナンス" Foreground="#374151" FontWeight="SemiBold" FontSize="14" Cursor="Hand" MouseLeftButtonUp="NavMaintenance_Click" Background="Transparent"/>
                    </StackPanel>

                    <Button Grid.Column="1" Content="ログアウト" Style="{StaticResource LogoutButtonStyle}" VerticalAlignment="Center">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6366F1" Offset="0"/>
                                <GradientStop Color="#4F46E5" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>

        <Popup x:Name="NavBudgetPopup" PlacementTarget="{Binding ElementName=NavBudget}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="10" HorizontalOffset="20">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Margin="0,0,12,12" Padding="0,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#22000000"/>
                </Border.Effect>
                <StackPanel MinWidth="200">
                    <TextBlock Text="長期予算" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" Padding="16,4,16,0"/>
                    
                    <TextBlock Text="部門経費予算" Style="{StaticResource MenuTextLink}" MouseLeftButtonDown="DepartmentBudgetLink_Click"/>
                    <TextBlock Text="ユーザーCSVインポート" Style="{StaticResource MenuTextLink}" MouseLeftButtonDown="UserCsvImportLink_Click"/>
                    
                    <TextBlock Text="社内売上仕入" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="課別営業予算" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="人件費取り込み" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="得意先別営業予算" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="ショップ別経費" Style="{StaticResource MenuTextLink}" MouseLeftButtonDown="ShopExpenseBudgetLink_Click"/>
                    <TextBlock Text="配賦関連入力" Style="{StaticResource MenuTextLink}"/>

                    <Border Height="1" Background="#E5E7EB" Margin="0,4"/>

                    <TextBlock Text="見通し予算" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" Padding="16,4,16,0"/>
                    <TextBlock Text="社内売上仕入" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="課別営業予算" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="経費・営業外" Style="{StaticResource MenuTextLink}" MouseLeftButtonDown="ExpenseNonOperatingForecastLink_Click"/>

                    <Border Height="1" Background="#E5E7EB" Margin="0,4"/>

                    <TextBlock Text="照会・その他" FontSize="12" FontWeight="Bold" Foreground="#9CA3AF" Padding="16,4,16,0"/>
                    <TextBlock Text="照会" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="課別見通し連携起動" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="社内売上作成（長期）起動" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="社内売上作成（見通し）起動" Style="{StaticResource MenuTextLink}"/>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="NavMaintenancePopup" PlacementTarget="{Binding ElementName=NavMaintenance}" Placement="Bottom" StaysOpen="False" AllowsTransparency="True" VerticalOffset="10" HorizontalOffset="20">
            <Border Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Margin="0,0,12,12" Padding="0,8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Color="#22000000"/>
                </Border.Effect>
                <StackPanel MinWidth="180">
                    <TextBlock Text="予算運用マスタ" Style="{StaticResource MenuTextLink}" MouseLeftButtonDown="BudgetOperationMasterLink_Click"/>
                    <TextBlock Text="予算係数マスタ" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="担当者マスタ" Style="{StaticResource MenuTextLink}"/>
                    <TextBlock Text="科目マスタ" Style="{StaticResource MenuTextLink}"/>
                </StackPanel>
            </Border>
        </Popup>

        <Grid Grid.Row="1" Margin="20">
            <Grid>
                <Border Background="White" CornerRadius="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="0" Color="#33000000"/>
                    </Border.Effect>
                </Border>

                <Border Background="White" CornerRadius="20" ClipToBounds="True">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
                </Border>
                
            </Grid>
        </Grid>
    </Grid>
</Page>